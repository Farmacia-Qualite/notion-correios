# =========================================================================
# Webhook
# =========================================================================
# Valor secreto que o Notion (botão Emitir Etiqueta) deve enviar no header
# Authorization: Bearer <WEBHOOK_SECRET>. Gere com: openssl rand -hex 32
WEBHOOK_SECRET=

# =========================================================================
# Notion
# =========================================================================
# Internal Integration Secret (https://www.notion.so/profile/integrations)
NOTION_TOKEN=
# ID da DB - Vendas (já conhecido)
NOTION_DB_VENDAS_ID=1f3c8afa-5d9e-804c-8db8-000b360afeac

# =========================================================================
# Remetente (Farmácia Qualité) - usado em toda etiqueta
# =========================================================================
REMETENTE_NOME=
REMETENTE_CNPJ=
REMETENTE_IE=
REMETENTE_LOGRADOURO=
REMETENTE_NUMERO=
REMETENTE_COMPLEMENTO=
REMETENTE_BAIRRO=
REMETENTE_CEP=
REMETENTE_CIDADE=
REMETENTE_UF=
REMETENTE_DDD=
REMETENTE_TELEFONE=
REMETENTE_EMAIL=

# =========================================================================
# Pacote padrão - PAC
# Limites Correios: cada lado >= 11 cm, A+L+C <= 200 cm, maior lado <= 105 cm
# Formato: 1=envelope | 2=caixa | 3=cilindro
# =========================================================================
PAC_PESO_G=
PAC_ALTURA_CM=
PAC_LARGURA_CM=
PAC_COMPRIMENTO_CM=
PAC_FORMATO=2
PAC_CODIGO_SERVICO=04510

# =========================================================================
# Pacote padrão - Sedex
# =========================================================================
SEDEX_PESO_G=
SEDEX_ALTURA_CM=
SEDEX_LARGURA_CM=
SEDEX_COMPRIMENTO_CM=
SEDEX_FORMATO=2
SEDEX_CODIGO_SERVICO=04014

# =========================================================================
# Correios CWS
# =========================================================================
CORREIOS_BASE_URL=https://api.correios.com.br
CORREIOS_USUARIO=
CORREIOS_SENHA=
CORREIOS_CONTRATO=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_COD_ADMINISTRATIVO=

# =========================================================================
# Cloudflare R2 (armazena os PDFs das etiquetas)
# =========================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=etiquetas-qualite
# URL pública do bucket (sem barra no final), ex: https://pub-xxxxx.r2.dev
R2_PUBLIC_URL=
